{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Smart Orders API",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/SmartOrders.Api/bin/Debug/net10.0/SmartOrders.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/SmartOrders.Api",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5101"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    }
  ]
}
